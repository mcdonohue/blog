@article{insel2025concurrent,
    author = {Insel, Philip S. and Mattsson-Carlgren, Niklas and Langford, Oliver and Caruso, Vincent M. and Leuzy, Antoine and Young, Christina B. and Boxer, Adam and Aisen, Paul S. and Sperling, Reisa A. and Mormino, Elizabeth C. and Donohue, Michael C.},
    title = {Concurrent Changes in Plasma Phosphorylated Tau 217, Tau PET, and Cognition in Preclinical {Alzheimer} Disease},
    journal = {JAMA Neurology},
    volume = {82},
    number = {10},
    pages = {985-993},
    year = {2025},
    month = {10},
    abstract = {Developing disease-modifying treatments is a priority for Alzheimer disease research.To determine the potential of plasma phosphorylated tau 217 (p-tau217) and tau positron emission tomography (PET) to assess disease modification in treatment trials.This diagnostic/prognostic study used longitudinal data from the Anti-Amyloid Treatment in Asymptomatic AlzheimerŌĆÖs Disease (A4) study collected from April 2014 to June 2023. Recruited from 67 sites in the US, Canada, Australia, and Japan, participants included older individuals (age 65-85 years) who were cognitively unimpaired at screening and underwent an amyloid PET scan. Participants without elevated amyloid PET were included from a companion to the A4 study, the Longitudinal Evaluation of Amyloid Risk and Neurodegeneration (LEARN) study.18F-florbetapir PET imaging.18F-florbetapir PET imaging was used to classify participants as having elevated amyloid ╬▓ (A╬▓+). Measures of tau included longitudinal plasma p-tau217 and 18F-flortaucipir PET. Cognition was assessed using the Preclinical Alzheimer Cognitive Composite (PACC).A total of 1169 individuals were included from A4 Study and 538 without elevated amyloid PET were included from the LEARN Study. Among these 1707 participants, the baseline mean (SD) age was 71.5 (4.7) years, 1024 (60\%) were female, and 683 (40\%) male; 1169 participants were A╬▓+, and the mean (SD) Mini-Mental State Examination score was 28.8 (1.2). The tau PET substudy included 443 participants; plasma p-tau217 levels were available for 1643 participants. The largest effect size of longitudinal tau PET accumulation at 36 months in A╬▓+ participants was in the inferior temporal gyrus. Baseline associations with longitudinal change in PACC score in A╬▓+ participants were strongest in the entorhinal cortex (correlation [Žü]ŌĆē=ŌĆēŌłÆ0.55; 95\% CI, ŌłÆ0.63 to ŌłÆ0.45) and plasma p-tau217 levels (ŽüŌĆē=ŌĆēŌłÆ0.47; 95\% CI, ŌłÆ0.56 to ŌłÆ0.37). Tau PET changes in frontoparietal regions were strongly correlated with concurrent cognitive changes. Levels of plasma p-tau217 increased significantly in A╬▓+ participants before showing significant deceleration (Žć2ŌĆē=ŌĆē21.7; PŌĆē\&lt;ŌĆē.001) and were not associated with concurrent cognitive change in the tau PET substudy (ŽüŌĆē=ŌĆēŌłÆ0.03; 95\% CI, ŌłÆ0.23 to 0.16) but were modestly associated with concurrent cognitive changes in the full plasma sample (nŌĆē=ŌĆē1119; ŽüŌĆē=ŌĆēŌłÆ0.24; 95\% CI, ŌłÆ0.34 to ŌłÆ0.14).This study found that tau PET is valuable for both prognostic and real-time tracking of disease progression. Plasma p-tau217 predicts cognitive changes prior to overt cognitive impairment and can efficiently guide participant selection. Imaging-based tau measures may enhance detection of disease-modifying effects and refine therapeutic targets in future Alzheimer disease trials.},
    issn = {2168-6149},
    doi = {10.1001/jamaneurol.2025.2974},
    url = {https://doi.org/10.1001/jamaneurol.2025.2974},
    eprint = {https://jamanetwork.com/journals/jamaneurology/articlepdf/2838121/jamaneurology_insel_2025_oi_250056_1770138155.02751.pdf},
}

